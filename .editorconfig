root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# One sentence per line in normative text; do not auto-wrap. Preserve trailing
# spaces off, but Markdown line breaks use explicit blank lines.
trim_trailing_whitespace = true
max_line_length = off

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2
